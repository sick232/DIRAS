# DIRAS Environment Configuration (Copy to .env and fill in values)

# Database
DATABASE_URL=postgresql://diras:diras123@localhost:5432/diras
DATABASE_ECHO=false

# Vector Database (ChromaDB)
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_COLLECTION_NAME=diras_documents

# Search (Elasticsearch)
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX_NAME=diras_documents

# LLM Configuration (Llama 3 local)
# Option 1: Local Ollama (run: ollama serve, in another terminal)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama2  # or llama2-13b, or your chosen model
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# Option 2: OpenAI (if you want to use OpenAI instead of local Llama)
# OPENAI_API_KEY=your-openai-api-key-here
# Use only if not using local Ollama

# Model Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
CLASSIFIER_MODEL_PATH=models/classification/classifier.pkl
NER_MODEL=en_core_web_sm

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO
ENVIRONMENT=development

# Data Paths
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_EMBEDDINGS_DIR=data/embeddings
MODELS_DIR=models

# Monitoring
PROMETHEUS_PORT=8002
GRAFANA_PORT=3000
METRICS_ENABLED=true

# Scraping Configuration
SCRAPER_TIMEOUT=30
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_DELAY_BETWEEN_REQUESTS=1

# OCR Configuration
OCR_LANGUAGES=en,hi
OCR_GPU=true  # Set to false if no GPU available
OCR_USE_LAYOUT_PARSER=true

# RAG Configuration
RAG_RETRIEVAL_TOP_K=5
RAG_CONTEXT_WINDOW=4000
RAG_RERANKER_TOP_K=10
HALLUCINATION_DETECTION_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/diras.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_ORIGINS=*

# Optional: HuggingFace Token (for private models)
# HUGGINGFACE_TOKEN=your-token-here
